# Fleet System — Szablon Konfiguracji Produkcyjnej
# Skopiuj ten plik do .env.prod i wypełnij rzeczywistymi wartościami
# NIGDY nie commituj .env.prod do gita!


# Tag obrazu/wersja (muszą zgadzać się z tym co wypchnąłeś)
IMAGE_TAG=1.0.0

# Port Frontendu (domyślnie: 80, użyj 8000+ dla portów bez uprawnień administratora)
FRONTEND_PORT=80

# Konfiguracja PostgreSQL
# ⚠️ Zmień POSTGRES_PASSWORD na mocne hasło 20+ znaków!
# Mieszaj: wielkie litery, małe litery, cyfry i znaki specjalne
POSTGRES_DB=fleet_mgmt
POSTGRES_USER=fleet_admin
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_WITH_SPECIAL_CHARS_123!@#

